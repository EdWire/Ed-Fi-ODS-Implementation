  <xs:complexType name="EXTENSION-EducationOrganizationProgramAuthorizedProviderIdentityType">
    <xs:annotation>
      <xs:documentation>Encapsulates primary attributes that can be used to look up the identity of an EducationOrganizationProgramAuthorizedProvider.</xs:documentation>
